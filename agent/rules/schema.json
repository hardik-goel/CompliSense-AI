{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["system_name","owner","review_cadence","risks","coverage"],
  "properties": {
    "system_name": {"type": "string"},
    "owner": {"type": "string"},
    "review_cadence": {"type": "string"},
    "coverage": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hazard","harm","severity","mitigation","status","evidence_ref"],
        "properties": {
          "hazard":{"type":"string"},
          "harm":{"type":"string"},
          "severity":{"type":"string","enum":["Low","Medium","High","Critical"]},
          "mitigation":{"type":"string"},
          "status":{"type":"string","enum":["Open","In Progress","Closed"]},
          "evidence_ref":{"type":"string"}
        }
      },
      "minItems": 1
    }
  }
}
