<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>Compliance Audit Report</title>
  <style>
    @page {
      size: A4 portrait;
      margin: 1cm;
    }
    body {
      font: 10px/1.35 system-ui, sans-serif;
      color: #1f2937;
      margin: 0;
      padding: 0;
    }
    h1, h2, h3 { margin: 0 0 0.35rem 0; page-break-after: avoid; }
    h1 { font-size: 20px; }
    h2 { font-size: 13px; margin-top: 0.9rem; }
    h3 { font-size: 11px; margin-top: 0.7rem; }
    p { margin: 0.2rem 0; }
    table {
      width: 100%;
      border-collapse: collapse; 
      margin: 0.5rem 0;
      page-break-inside: avoid;
    }
    th, td {
      border: 1px solid #d1d5db;
      padding: 5px 4px;
      vertical-align: top;
      text-align: left;
    }
    th {
      background: #f3f4f6;
      font-weight: 700;
      font-size: 9px;
    }
    .page-break { page-break-before: always; }
    .hero {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 10px;
      align-items: stretch;
    }
    .panel {
      border: 1px solid #d1d5db;
      border-radius: 8px;
      padding: 10px;
      background: #fff;
    }
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-top: 8px;
    }
    .metric {
      border: 1px solid #d1d5db;
      border-radius: 8px;
      padding: 8px;
      background: #f9fafb;
      text-align: center;
    }
    .metric .value {
      display: block;
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 2px;
    }
    .metric .label {
      font-size: 8px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #6b7280;
    }
    .small { color: #6b7280; font-size: 8px; }
    .PASS { color: #157347; font-weight: 700; }
    .FAIL, .HIGH { color: #b02a37; font-weight: 700; }
    .MISSING, .PARTIAL, .MEDIUM { color: #b45309; font-weight: 700; }
    .LOW { color: #157347; }
    .list-block {
      margin: 0.35rem 0 0;
      padding-left: 1rem;
    }
    .list-block li {
      margin: 0.18rem 0;
    }
    .tight-table th:nth-child(1), .tight-table td:nth-child(1) { width: 34%; }
    .tight-table th:nth-child(2), .tight-table td:nth-child(2) { width: 12%; }
    .tight-table th:nth-child(3), .tight-table td:nth-child(3) { width: 12%; }
    .tight-table th:nth-child(4), .tight-table td:nth-child(4) { width: 12%; }
    .tight-table th:nth-child(5), .tight-table td:nth-child(5) { width: 12%; }
    .tight-table th:nth-child(6), .tight-table td:nth-child(6) { width: 18%; }
    .result-table th:nth-child(1), .result-table td:nth-child(1) { width: 28%; }
    .result-table th:nth-child(2), .result-table td:nth-child(2) { width: 8%; }
    .result-table th:nth-child(3), .result-table td:nth-child(3) { width: 9%; }
    .result-table th:nth-child(4), .result-table td:nth-child(4) { width: 10%; }
    .result-table th:nth-child(5), .result-table td:nth-child(5) { width: 10%; }
    .result-table th:nth-child(6), .result-table td:nth-child(6) { width: 10%; }
    .result-table th:nth-child(7), .result-table td:nth-child(7) { width: 25%; }
    .page-note {
      margin-top: 0.5rem;
      padding-top: 0.35rem;
      border-top: 1px solid #e5e7eb;
    }
  </style>
</head>
<body>
{% set total_rules = results|length %}
{% set passed = summary.passed %}
{% set partial = summary.partial %}
{% set failed = summary.failed %}
{% set present_count = artifacts.present|length %}
{% set missing_artifacts_count = artifacts.missing|length %}
<h1>Compliance Audit Report</h1>
<div class="small">Generated: {{ now }}</div>
<div class="hero">
  <div class="panel">
    <h2>Assessment</h2>
    <p><strong>Verdict:</strong> {{ assessment.verdict }}</p>
    <p><strong>Overall compliance:</strong> {{ assessment.overall_compliance_pct }}%</p>
    <p><strong>Artifact compliance:</strong> {{ artifacts.compliance_pct }}%</p>
    <p><strong>Average rule confidence:</strong> {{ assessment.avg_rule_confidence }}%</p>

    <div class="metric-grid">
      <div class="metric"><span class="value">{{ total_rules }}</span><span class="label">Rules checked</span></div>
      <div class="metric"><span class="value PASS">{{ passed }}</span><span class="label">Passed</span></div>
      <div class="metric"><span class="value PARTIAL">{{ partial }}</span><span class="label">Partial or missing</span></div>
      <div class="metric"><span class="value FAIL">{{ failed }}</span><span class="label">Failed</span></div>
    </div>
  </div>
  <div class="panel">
    <h2>Interpretation</h2>
    <p><strong>Overall compliance</strong> blends artifact readiness and rule confidence into one percentage.</p>
    <p><strong>Artifact compliance</strong> shows how many required governance files were found.</p>
    <p><strong>Rule confidence</strong> indicates how strongly the available evidence supports each rule result.</p>
    <p><strong>Risk</strong> combines confidence with rule severity to prioritize attention.</p>
  </div>
</div>

<h2>Artifact Coverage</h2>
<table class="tight-table">
  <tr>
    <th>Metric</th>
    <th>Present</th>
    <th>Missing</th>
    <th>Total</th>
    <th>Coverage</th>
    <th>Notes</th>
  </tr>
  <tr>
    <td>Required governance artifacts</td>
    <td>{{ present_count }}</td>
    <td>{{ missing_artifacts_count }}</td>
    <td>{{ artifacts.required_total }}</td>
    <td>{{ artifacts.compliance_pct }}%</td>
    <td>{% if missing_artifacts_count %}Missing items reduce legal readiness and often explain failed rules.{% else %}All required artifacts were found.{% endif %}</td>
  </tr>
</table>

<h3>Key Gaps</h3>
{% if assessment.why_not_compliant.missing_artifacts or assessment.why_not_compliant.failed_rules %}
<ul class="list-block">
  {% for a in assessment.why_not_compliant.missing_artifacts[:4] %}
    <li>Missing artifact: {{ a }}</li>
  {% endfor %}
  {% for r in assessment.why_not_compliant.failed_rules[:4] %}
    <li>Failed rule: {{ r }}</li>
  {% endfor %}
</ul>
{% else %}
<p>No blocking gaps identified in this run.</p>
{% endif %}

<div class="page-break"></div>
<h2>Rule Findings</h2>
<table class="result-table">
  <thead>
    <tr>
      <th>Rule</th>
      <th>Clause</th>
      <th>Severity</th>
      <th>Status</th>
      <th>Confidence</th>
      <th>Risk</th>
      <th>Evidence & Remediation</th>
    </tr>
  </thead>
  <tbody>
    {% for item in results %}
    <tr>
      <td>
        {{ item.title }}
        <div class="small">{{ item.rule_id }}</div>
      </td>
      <td>{{ item.clause }}</td>
      <td>{{ item.severity }}</td>
      <td class="{{ item.status }}">{{ item.status }}</td>
      <td>{{ item.confidence }}%</td>
      <td class="{{ item.risk }}">{{ item.risk }}</td>
      <td>
        {% if item.evidence.missing_file %}
          Missing file: {{ item.files_used|join(", ") }}
        {% elif item.evidence.missing_fields %}
          Missing fields: {{ item.evidence.missing_fields|join(", ") }}
        {% elif item.evidence.coverage_score is defined %}
          Coverage score {{ "%.0f"|format(item.evidence.coverage_score * 100) }}%
        {% elif item.evidence.coverage is defined %}
          Coverage {{ "%.0f"|format(item.evidence.coverage * 100) }}%
        {% elif item.evidence.validation_report and item.evidence.validation_report != "ok" %}
          {{ item.evidence.validation_report[:80] }}{% if item.evidence.validation_report|length > 80 %}...{% endif %}
        {% else %}
          {{ item.remediation[0] if item.remediation else "No additional action required." }}
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<div class="page-note small">
This report is an automated compliance aid. It summarizes detected documentation and rule evidence at scan time and does not replace legal review.
</div>

</body>
</html>
