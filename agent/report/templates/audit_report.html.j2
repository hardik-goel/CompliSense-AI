<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>EU AI Act Audit Report</title>
  <style>
    body { font: 14px/1.5 system-ui, sans-serif; color: #222; }
    h1, h2 { margin-bottom: 0.4rem; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th, td { border: 1px solid #ddd; padding: 8px; vertical-align: top; }
    th { background: #f5f5f5; }
    .PASS { color: #157347; font-weight: 700; }
    .FAIL { color: #b02a37; font-weight: 700; }
    .MISSING { color: #fd7e14; font-weight: 700; }
    .PARTIAL { color: #fd7e14; font-weight: 700; }
    .LOW { color: #157347; }
    .MEDIUM { color: #fd7e14; }
    .HIGH { color: #b02a37; font-weight: 700; }
    .small { color: #666; font-size: 12px; }
  </style>
</head>
<body>

<h1>EU AI Act Audit Report</h1>
<div class="small">Generated: {{ now }}</div>

<h2>Overall Compliance Assessment</h2>

<p>
<strong>Verdict:</strong> {{ assessment.verdict }}<br/>
<strong>Overall Compliance:</strong> {{ assessment.overall_compliance_pct }}%
</p>
<h2>Summary</h2>
<p>
Passed: {{ summary.passed }} &nbsp;
Warnings (Missing / Partial): {{ summary.partial }} &nbsp;
Failed: {{ summary.failed }}
</p>

<h2>Required EU AI Act Artifacts</h2>

<p>
Overall artifact compliance:
<strong>{{ artifacts.compliance_pct }}%</strong>
</p>

{% if artifacts.missing %}
<table>
  <tr>
    <th>Artifact</th>
    <th>EU AI Act Article</th>
    <th>Description</th>
  </tr>
  {% for a in artifacts.missing %}
  <tr>
    <td>{{ a.name }}</td>
    <td>{{ a.article }}</td>
    <td>{{ a.description }}</td>
  </tr>
  {% endfor %}
</table>
{% else %}
<p><strong>All required artifacts are present.</strong></p>
{% endif %}


<h2>Findings</h2>

<table>
  <thead>
    <tr>
      <th>Rule</th>
      <th>Clause</th>
      <th>Severity</th>
      <th>Status</th>
      <th>Confidence</th>
      <th>Risk</th>
      <th>Evidence & Remediation</th>
    </tr>
  </thead>
  <tbody>
    {% for item in results %}
    <tr>
      <td>
        {{ item.title }}
        <div class="small">{{ item.rule_id }}</div>
      </td>
      <td>{{ item.clause }}</td>
      <td>{{ item.severity }}</td>
      <td class="{{ item.status }}">{{ item.status }}</td>
      <td>{{ item.confidence }}%</td>
      <td class="{{ item.risk }}">{{ item.risk }}</td>
      <td>
      {% if item.status == "MISSING" %}
        <strong>Missing evidence</strong>
        <ul>
          {% for f in item.files_used %}
            <li>{{ f }}</li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if item.remediation %}
        <div class="small"><strong>Recommended actions:</strong></div>
        <ul>
          {% for r in item.remediation %}
            <li>{{ r }}</li>
          {% endfor %}
        </ul>
      {% elif item.status != "PASS" %}
        <span class="small">No remediation guidance available.</span>
      {% else %}
        —
      {% endif %}
    </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<h2>Why This System Is Not Compliant</h2>

{% if assessment.why_not_compliant.missing_artifacts %}
<p><strong>Missing required governance artifacts:</strong></p>
<ul>
  {% for a in assessment.why_not_compliant.missing_artifacts %}
    <li>{{ a }}</li>
  {% endfor %}
</ul>
{% endif %}

{% if assessment.why_not_compliant.failed_rules %}
<p><strong>Rules indicating non-compliance:</strong></p>
<ul>
  {% for r in assessment.why_not_compliant.failed_rules %}
    <li>{{ r }}</li>
  {% endfor %}
</ul>
{% endif %}

<h2>Scope & Limitations</h2>

<p class="small">
This assessment does <strong>NOT</strong> validate the following unless
explicit supporting artifacts were provided:
</p>

<ul class="small">
  <li>Model performance, accuracy, or benchmarking claims</li>
  <li>Bias, fairness, or discrimination metrics</li>
  <li>Dataset representativeness or sampling validity</li>
  <li>Legal enforceability of internal policies</li>
  <li>Operational effectiveness of governance controls</li>
</ul>

<h2>Disclaimer</h2>
<p class="small">
This automated assessment is advisory and based on artifacts available at scan time.
It does not constitute legal advice.
</p>

</body>
</html>
