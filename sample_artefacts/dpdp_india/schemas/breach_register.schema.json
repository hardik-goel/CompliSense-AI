{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["coverage", "incidents"],
  "properties": {
    "coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "incidents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "incident_id",
          "date_detected",
          "severity",
          "affected_data_categories",
          "containment_status",
          "notification_decision"
        ],
        "properties": {
          "incident_id": { "type": "string" },
          "date_detected": { "type": "string" },
          "severity": { "type": "string" },
          "affected_data_categories": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "containment_status": { "type": "string" },
          "notification_decision": { "type": "string" }
        }
      }
    }
  }
}
