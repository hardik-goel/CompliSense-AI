{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["coverage", "processors"],
  "properties": {
    "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "processors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "service_category", "data_categories", "contract_owner", "review_cycle"],
        "properties": {
          "name": { "type": "string" },
          "service_category": { "type": "string" },
          "data_categories": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "contract_owner": { "type": "string" },
          "review_cycle": { "type": "string" }
        }
      }
    }
  }
}
